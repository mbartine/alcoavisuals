---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is corporate photography used for?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Corporate photography is used for marketing materials, websites, social media, annual reports, press releases, and internal communications. Professional images help establish credibility and present a polished brand image to clients and stakeholders."
      }
    },
    {
      "@type": "Question",
      "name": "Do you do product photography for e-commerce?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, Alcoa Visuals provides professional product photography suitable for e-commerce platforms, catalogs, and marketing materials. We work with you to capture your products in the best light with clean, professional results."
      }
    },
    {
      "@type": "Question",
      "name": "How much does corporate photography cost in Knoxville?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Corporate photography pricing in Knoxville depends on the scope of the shoot, number of images needed, and whether on-location travel is required. Contact Alcoa Visuals for a custom quote based on your project."
      }
    },
    {
      "@type": "Question",
      "name": "What is the turnaround time for a photography shoot?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Edited photos are typically delivered within 5-10 business days after the shoot, depending on the number of images and retouching required. Rush delivery is available for time-sensitive projects."
      }
    },
    {
      "@type": "Question",
      "name": "Do you provide on-location photography?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, we shoot on location at your business, facility, or any setting in the Knoxville and East Tennessee area. On-location photography captures your brand in its authentic environment, which often produces more compelling results than studio work."
      }
    }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Corporate Photography",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Alcoa Visuals"
  },
  "areaServed": "Knoxville, Tennessee",
  "description": "Professional corporate photography including product, facility, headshot, and brand imagery."
};

const specialties = [
  {
    title: 'Product Photography',
    desc: 'Clean, professional product shots for e-commerce, catalogs, and marketing materials.',
    icon: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4'
  },
  {
    title: 'Location & Facility',
    desc: 'Showcase your workspace, facilities, and business environment with professional imagery.',
    icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4'
  },
  {
    title: 'Corporate Headshots',
    desc: 'Professional headshots and team photos that present your people at their best.',
    icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z'
  },
  {
    title: 'Brand Imagery',
    desc: 'Custom photography that captures your brand identity and tells your company story.',
    icon: 'M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z'
  },
];
---

<BaseLayout
  title="Corporate Photography Services | Knoxville"
  description="Professional corporate photography in Knoxville, TN. Product photos, facility images, headshots, and brand imagery by Alcoa Visuals."
  keywords={['corporate photography', 'Knoxville photographer', 'product photography', 'headshots', 'business photography']}
>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  </Fragment>

  <!-- Hero -->
  <section class="relative pt-40 pb-xl overflow-hidden">
    <img src="/images/portfolio/corporate-promotion.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 bg-accent-purple/60"></div>
    <div class="container-wide relative z-10">
      <h1 class="fade-up">Corporate Photography</h1>
      <p class="mt-4 text-gray-light text-h3 max-w-2xl mx-auto text-center fade-up" style="transition-delay: 0.1s">
        Professional imagery for your business in Knoxville and East Tennessee
      </p>
    </div>
  </section>

  <!-- Specialties -->
  <section class="py-2xl bg-off-black">
    <div class="container-wide">
      <div class="max-w-3xl mx-auto mb-16">
        <span class="section-label fade-up">Specialties</span>
        <h2 class="mt-4 mb-6 fade-up" style="transition-delay: 0.1s">Photography That Means Business</h2>
        <p class="text-gray-light fade-up" style="transition-delay: 0.2s">
          We focus exclusively on corporate and commercial photography — professional images that serve your business goals.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        {specialties.map((item, i) => (
          <div class="glass p-8 fade-up text-center" style={`transition-delay: ${(i + 3) * 0.1}s`}>
            <svg class="w-10 h-10 text-white mb-4 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={item.icon} />
            </svg>
            <h3 class="text-h3 mb-3">{item.title}</h3>
            <p class="text-gray-light">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Video Cross-link -->
  <section class="py-xl bg-charcoal">
    <div class="container-wide">
      <div class="space-y-8">
        <div class="glass glass-tint-blue p-8 md:p-12 fade-up">
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div>
              <span class="section-label">Also Available</span>
              <h3 class="mt-2 mb-4 text-h2">Need Video Too?</h3>
              <p class="text-gray-light">
                Many of our photography clients also need video production. We offer seamless integration of both services to maximize your shoot days and budget.
              </p>
            </div>
            <div class="text-center md:text-right">
              <a href="/video-services" class="btn-outline">View Video Services &rarr;</a>
            </div>
          </div>
        </div>

        <div class="glass glass-tint-purple p-8 md:p-12 fade-up" style="transition-delay: 0.1s">
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div>
              <span class="section-label">AI-Enhanced</span>
              <h3 class="mt-2 mb-4 text-h2">Turn Photos Into Video Reels</h3>
              <p class="text-gray-light">
                Want more from your photo shoot? Our AI-enhanced media services can transform your professional photos into short marketing reels, social content, and more.
              </p>
            </div>
            <div class="text-center md:text-right">
              <a href="/ai-media-services" class="btn-outline">View AI Media Services &rarr;</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-2xl bg-off-black">
    <div class="container-wide">
      <div class="max-w-3xl mx-auto">
        <span class="section-label fade-up">FAQ</span>
        <h2 class="mt-4 mb-12 fade-up" style="transition-delay: 0.1s">Frequently Asked Questions</h2>

        <div class="space-y-8">
          <div class="glass p-8 fade-up" style="transition-delay: 0.2s">
            <h3 class="text-h3 mb-4">What is corporate photography used for?</h3>
            <p class="text-gray-light">
              Corporate photography is used for marketing materials, websites, social media, annual reports, press releases, and internal communications. Professional images help establish credibility and present a polished brand image to clients and stakeholders.
            </p>
          </div>

          <div class="glass p-8 fade-up" style="transition-delay: 0.3s">
            <h3 class="text-h3 mb-4">Do you do product photography for e-commerce?</h3>
            <p class="text-gray-light">
              Yes, we provide professional product photography suitable for e-commerce platforms, catalogs, and marketing materials. We work with you to capture your products in the best light with clean, professional results.
            </p>
          </div>

          <div class="glass p-8 fade-up" style="transition-delay: 0.4s">
            <h3 class="text-h3 mb-4">How much does corporate photography cost in Knoxville?</h3>
            <p class="text-gray-light">
              Corporate photography pricing in Knoxville depends on the scope of the shoot, number of images needed, and whether on-location travel is required. Contact us for a custom quote based on your project.
            </p>
          </div>

          <div class="glass p-8 fade-up" style="transition-delay: 0.5s">
            <h3 class="text-h3 mb-4">What is the turnaround time for a photography shoot?</h3>
            <p class="text-gray-light">
              Edited photos are typically delivered within 5-10 business days after the shoot, depending on the number of images and retouching required. Rush delivery is available for time-sensitive projects.
            </p>
          </div>

          <div class="glass p-8 fade-up" style="transition-delay: 0.6s">
            <h3 class="text-h3 mb-4">Do you provide on-location photography?</h3>
            <p class="text-gray-light">
              Yes, we shoot on location at your business, facility, or any setting in the Knoxville and East Tennessee area. On-location photography captures your brand in its authentic environment, which often produces more compelling results than studio work.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-2xl bg-black">
    <div class="container-wide">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="mb-6 fade-up">Book a Photography Session</h2>
        <p class="text-gray-light mb-8 fade-up" style="transition-delay: 0.1s">
          Let's discuss your photography needs and create images that elevate your brand.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center fade-up" style="transition-delay: 0.2s">
          <a href="/contact" class="btn-glass">Get a Quote</a>
          <a href="tel:8652389877" class="btn-outline">Call 865.238.9877</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
