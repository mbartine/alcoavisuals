---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Alcoa Visuals | Knoxville Video Production"
  description="Get a quote for video production, photography, or workshops. Contact Alcoa Visuals in Alcoa, TN. Call 865.238.9877."
  keywords={['contact Alcoa Visuals', 'Knoxville video production quote', 'video production inquiry']}
>
  <!-- Hero -->
  <section class="relative pt-40 pb-xl overflow-hidden">
    <img src="/images/portfolio/corporate-promotion.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 bg-black/70"></div>
    <div class="container-wide relative z-10">
      <h1 class="fade-up">Let's Start Your Project</h1>
      <p class="mt-4 text-gray-light text-h3 max-w-2xl mx-auto text-center fade-up" style="transition-delay: 0.1s">
        Tell us about your vision and we'll help bring it to life
      </p>
    </div>
  </section>

  <!-- Contact Form + Info -->
  <section class="py-xl bg-off-black">
    <div class="container-wide">
      <div class="grid lg:grid-cols-3 gap-12">
        <!-- Form -->
        <div class="lg:col-span-2">
          <form
            name="contact"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="space-y-8"
          >
            <p class="hidden">
              <label>Don't fill this out: <input name="bot-field" /></label>
            </p>
            <input type="hidden" name="form-name" value="contact" />

            <div class="grid md:grid-cols-2 gap-8">
              <div class="fade-up">
                <label for="name" class="block text-small uppercase tracking-wide mb-2">
                  Name
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full glass-input px-6 py-4 text-white placeholder-gray-mid focus:border-white focus:outline-none transition-colors"
                  placeholder="Your name"
                />
              </div>

              <div class="fade-up" style="transition-delay: 0.1s">
                <label for="email" class="block text-small uppercase tracking-wide mb-2">
                  Email
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full glass-input px-6 py-4 text-white placeholder-gray-mid focus:border-white focus:outline-none transition-colors"
                  placeholder="your@email.com"
                />
              </div>
            </div>

            <div class="grid md:grid-cols-2 gap-8">
              <div class="fade-up" style="transition-delay: 0.2s">
                <label for="phone" class="block text-small uppercase tracking-wide mb-2">
                  Phone <span class="text-gray-mid">(optional)</span>
                </label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  class="w-full glass-input px-6 py-4 text-white placeholder-gray-mid focus:border-white focus:outline-none transition-colors"
                  placeholder="(865) 555-0000"
                />
              </div>

              <div class="fade-up" style="transition-delay: 0.3s">
                <label for="project-type" class="block text-small uppercase tracking-wide mb-2">
                  Project Type
                </label>
                <select
                  id="project-type"
                  name="project-type"
                  required
                  class="w-full glass-input px-6 py-4 text-white focus:border-white focus:outline-none transition-colors"
                >
                  <option value="">Select a project type...</option>
                  <option value="corporate-video">Corporate Video Production</option>
                  <option value="tv-commercial">TV Commercial</option>
                  <option value="testimonial">Testimonial Video</option>
                  <option value="corporate-photography">Corporate Photography</option>
                  <option value="photography-workshop">Photography Workshop</option>
                  <option value="other">Other</option>
                </select>
              </div>
            </div>

            <div class="fade-up" style="transition-delay: 0.4s">
              <label for="message" class="block text-small uppercase tracking-wide mb-2">
                Message
              </label>
              <textarea
                id="message"
                name="message"
                rows="6"
                required
                class="w-full glass-input px-6 py-4 text-white placeholder-gray-mid focus:border-white focus:outline-none transition-colors resize-none"
                placeholder="Tell us about your project..."
              ></textarea>
            </div>

            <div class="fade-up" style="transition-delay: 0.5s">
              <button type="submit" class="btn-primary w-full sm:w-auto">
                Send Message
              </button>
            </div>
          </form>
        </div>

        <!-- Contact Info Sidebar -->
        <div class="lg:col-span-1">
          <div class="glass p-8 fade-up" style="transition-delay: 0.3s">
            <h2 class="text-h3 mb-6">Get in Touch</h2>

            <div class="space-y-6">
              <div>
                <h3 class="text-small uppercase tracking-wide text-gray-mid mb-2">Phone</h3>
                <a href="tel:8652389877" class="text-white hover:text-gray-light text-lg">
                  865.238.9877
                </a>
              </div>

              <div>
                <h3 class="text-small uppercase tracking-wide text-gray-mid mb-2">Email</h3>
                <a href="mailto:brad@bradcvideo.com" class="text-white hover:text-gray-light">
                  brad@bradcvideo.com
                </a>
              </div>

              <div>
                <h3 class="text-small uppercase tracking-wide text-gray-mid mb-2">Address</h3>
                <p class="text-gray-light">
                  1330 Remsen Street<br />
                  Alcoa, TN 37701
                </p>
              </div>

              <hr class="border-charcoal" />

              <div>
                <h3 class="text-small uppercase tracking-wide text-gray-mid mb-4">Follow Us</h3>
                <div class="flex gap-4">
                  <a href="https://www.facebook.com/betherecreative/" target="_blank" rel="noopener" class="text-gray-light hover:text-white" aria-label="Facebook">
                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                    </svg>
                  </a>
                  <a href="https://www.instagram.com/bradcoulter/" target="_blank" rel="noopener" class="text-gray-light hover:text-white" aria-label="Instagram">
                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                    </svg>
                  </a>
                  <a href="https://www.linkedin.com/company/be-there-creative" target="_blank" rel="noopener" class="text-gray-light hover:text-white" aria-label="LinkedIn">
                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                    </svg>
                  </a>
                  <a href="https://www.flickr.com/people/betherecreative/" target="_blank" rel="noopener" class="text-gray-light hover:text-white" aria-label="Flickr">
                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M0 12c0 3.074 2.494 5.564 5.565 5.564 3.075 0 5.569-2.49 5.569-5.564S8.641 6.436 5.565 6.436C2.495 6.436 0 8.926 0 12zm12.866 0c0 3.074 2.493 5.564 5.567 5.564C21.496 17.564 24 15.074 24 12s-2.504-5.564-5.567-5.564c-3.074 0-5.567 2.49-5.567 5.564z"/>
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
