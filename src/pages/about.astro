---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About Brad Coulter | Knoxville Videographer"
  description="Brad Coulter brings a storytelling-first approach to video production. BA in Creative Writing from UT, serving Knoxville and East Tennessee."
  keywords={['Brad Coulter', 'Knoxville videographer', 'video producer', 'Alcoa TN', 'East Tennessee videographer']}
>
  <!-- Hero -->
  <section class="relative pt-40 pb-xl overflow-hidden">
    <img src="/images/brad/headshot.jpg" alt="Brad Coulter" class="absolute inset-0 w-full h-full object-cover object-top" />
    <div class="absolute inset-0 bg-black/65"></div>
    <div class="container-wide relative z-10">
      <h1 class="fade-up">About Brad Coulter</h1>
      <p class="mt-4 text-gray-light text-h3 max-w-2xl mx-auto text-center fade-up" style="transition-delay: 0.1s">
        Storytelling-first video production in Alcoa, Tennessee
      </p>
    </div>
  </section>

  <!-- Bio -->
  <section class="py-2xl bg-off-black">
    <div class="container-wide">
      <div class="max-w-3xl mx-auto">
        <span class="section-label fade-up">The Story</span>
        <h2 class="mt-4 mb-8 fade-up" style="transition-delay: 0.1s">Video Production Is Storytelling</h2>

        <div class="space-y-6 text-gray-light fade-up" style="transition-delay: 0.2s">
          <p>
            At its core, video production is storytelling. While Brad has the professional cameras and technical gear to capture the shot, his focus is on the narrative behind it. With a bachelor's degree in Creative Writing from the University of Tennessee, he doesn't just record events — he crafts stories.
          </p>
          <p>
            Brad combines his writing background with years of production experience to help clients articulate their message clearly. The goal is collaboration: transforming ideas into productions both parties can be proud of.
          </p>
          <p>
            Alcoa Visuals is a full-service video production firm located in Alcoa, TN, serving the greater Knoxville area. Services span all aspects of video production including planning, scripting, filming, editing, motion graphics, and audio.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Fox vs Lion -->
  <section class="py-2xl bg-charcoal">
    <div class="container-wide">
      <div class="max-w-3xl mx-auto">
        <div class="glass glass-tint-blue p-8 md:p-12 fade-up">
          <span class="section-label">The Alcoa Visuals Approach</span>
          <h2 class="mt-4 mb-6">Agility Over Red Tape</h2>
          <blockquote class="text-h3 font-accent italic text-white mb-8">
            "An old German proverb says, 'What the lion cannot manage to do, the fox can.'"
          </blockquote>
          <div class="space-y-4 text-gray-light">
            <p>
              Large agencies often get bogged down by red tape and committees, making it difficult to give clients the attention they deserve.
            </p>
            <p>
              Alcoa Visuals takes a different approach — relying on agility, strategy, and ingenuity rather than brute force. Cutting through the noise to solve problems efficiently.
            </p>
            <p>
              You get a direct partnership through every phase of production, from concept to final delivery. No committees, no runaround — just responsive, focused service.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Summary -->
  <section class="py-2xl bg-off-black">
    <div class="container-wide">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <span class="section-label fade-up">Full Service</span>
        <h2 class="mt-4 mb-6 fade-up" style="transition-delay: 0.1s">What We Offer</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <a href="/video-services" class="glass p-6 text-center group fade-up" style="transition-delay: 0.2s">
          <h3 class="text-h3 mb-3 group-hover:text-accent-blue transition-colors">Video Production</h3>
          <p class="text-gray-light text-small">Corporate video, TV commercials, testimonials, and more</p>
        </a>
        <a href="/photography" class="glass p-6 text-center group fade-up" style="transition-delay: 0.3s">
          <h3 class="text-h3 mb-3 group-hover:text-accent-purple transition-colors">Photography</h3>
          <p class="text-gray-light text-small">Product, facility, headshot, and brand photography</p>
        </a>
        <a href="/workshops" class="glass p-6 text-center group fade-up" style="transition-delay: 0.4s">
          <h3 class="text-h3 mb-3 group-hover:text-accent-green transition-colors">Workshops</h3>
          <p class="text-gray-light text-small">Group and private photography instruction</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Location -->
  <section class="py-2xl bg-charcoal">
    <div class="container-wide">
      <div class="max-w-3xl mx-auto text-center">
        <span class="section-label fade-up">Location</span>
        <h2 class="mt-4 mb-6 fade-up" style="transition-delay: 0.1s">Serving East Tennessee</h2>
        <p class="text-gray-light mb-4 fade-up" style="transition-delay: 0.2s">
          Based in Alcoa, TN, we serve the greater Knoxville area including Maryville, Oak Ridge, and the surrounding Blount County region.
        </p>
        <p class="text-gray-mid fade-up" style="transition-delay: 0.3s">
          186 Airport Plaza Blvd., Suite B, Alcoa, TN 37701
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-2xl bg-black">
    <div class="container-wide">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="mb-6 fade-up">Let's Work Together</h2>
        <p class="text-gray-light mb-8 fade-up" style="transition-delay: 0.1s">
          Ready to start your next project? Get in touch and let's discuss how we can bring your vision to life.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center fade-up" style="transition-delay: 0.2s">
          <a href="/contact" class="btn-glass">Contact Us</a>
          <a href="tel:8652389877" class="btn-outline">Call 865.238.9877</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
