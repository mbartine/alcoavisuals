---
const currentYear = new Date().getFullYear();
---

<footer class="bg-black py-xl">
  <div class="container-wide">
    <div class="grid md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <a href="/" class="inline-block hover:opacity-80 transition-opacity">
          <img src="/images/Vertical-logo.png" alt="Alcoa Visuals" class="h-20 w-auto footer-logo" />
        </a>
        <p class="mt-2 text-gray-mid text-small">
          Video Production &middot; Photography &middot; Knoxville, TN
        </p>
      </div>

      <!-- Navigation -->
      <nav>
        <ul class="flex flex-wrap gap-6">
          <li>
            <a href="/video-services" class="link-underline text-gray-light hover:text-white text-small">
              Video
            </a>
          </li>
          <li>
            <a href="/photography" class="link-underline text-gray-light hover:text-white text-small">
              Photography
            </a>
          </li>
          <li>
            <a href="/workshops" class="link-underline text-gray-light hover:text-white text-small">
              Workshops
            </a>
          </li>
          <li>
            <a href="/postcards" class="link-underline text-gray-light hover:text-white text-small">
              Postcards
            </a>
          </li>
          <li>
            <a href="/about" class="link-underline text-gray-light hover:text-white text-small">
              About
            </a>
          </li>
          <li>
            <a href="/contact" class="link-underline text-gray-light hover:text-white text-small">
              Contact
            </a>
          </li>
        </ul>
      </nav>

      <!-- Contact Info (NAP for local SEO) -->
      <div class="text-small text-gray-light">
        <p>1330 Remsen Street</p>
        <p>Alcoa, TN 37701</p>
        <p class="mt-2">
          <a href="tel:8652389877" class="hover:text-white">865.238.9877</a>
        </p>
        <p>
          <a href="mailto:brad@bradcvideo.com" class="hover:text-white">brad@bradcvideo.com</a>
        </p>
      </div>
    </div>

    <hr class="my-8 border-charcoal" />

    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 text-gray-mid text-caption">
      <p>&copy; {currentYear} Alcoa Visuals. All rights reserved.</p>
      <div class="flex gap-6">
        <!-- Facebook -->
        <a href="https://www.facebook.com/betherecreative/" target="_blank" rel="noopener" class="hover:text-white" aria-label="Facebook">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
