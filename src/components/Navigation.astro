---
const navItems = [
  { label: 'Video', href: '/video-services' },
  { label: 'Photography', href: '/photography' },
  { label: 'AI Media', href: '/ai-media-services' },
  { label: 'Workshops', href: '/workshops' },
  { label: 'Postcards', href: '/postcards' },
  { label: 'About', href: '/about' },
];

const currentPath = Astro.url.pathname;
---

<header id="nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-normal bg-white/80 backdrop-blur-sm">
  <nav class="container-wide py-6 flex items-center justify-between">
    <a href="/" class="shrink-0 hover:opacity-80 transition-opacity">
      <img src="/images/horizontal-logo.png" alt="Alcoa Visuals" class="w-auto shrink-0" style="height: 95px; margin-top: 8px; margin-right: 40px;" />
    </a>

    <!-- Desktop Navigation -->
    <ul class="hidden md:flex items-center gap-6">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={[
              'link-underline font-body text-base uppercase tracking-normal whitespace-nowrap',
              currentPath.startsWith(item.href) ? 'text-black' : 'text-gray-mid hover:text-black'
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="/contact"
          class="whitespace-nowrap px-5 py-2.5 text-base uppercase tracking-normal font-medium bg-black/80 text-white rounded hover:bg-black transition-colors"
        >
          Contact
        </a>
      </li>
    </ul>

    <!-- Mobile Menu Button -->
    <button
      id="menu-toggle"
      class="md:hidden p-2 text-black"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path
          id="menu-icon"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"
        />
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu Overlay -->
  <div
    id="mobile-menu"
    class="fixed inset-0 bg-black/90 backdrop-blur-md z-40 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-normal md:hidden"
  >
    <ul class="text-center space-y-8">
      {navItems.map((item, index) => (
        <li
          class="mobile-nav-item opacity-0 translate-y-4"
          style={`transition-delay: ${index * 100}ms`}
        >
          <a
            href={item.href}
            class="font-display text-h2 uppercase tracking-headline hover:text-gray-light"
          >
            {item.label}
          </a>
        </li>
      ))}
      <li
        class="mobile-nav-item opacity-0 translate-y-4"
        style={`transition-delay: ${navItems.length * 100}ms`}
      >
        <a
          href="/contact"
          class="inline-block px-8 py-4 bg-white text-black font-display text-h3 uppercase tracking-headline hover:bg-gray-light transition-colors"
        >
          Contact
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const nav = document.getElementById('nav');
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const mobileNavItems = document.querySelectorAll('.mobile-nav-item');

  let isMenuOpen = false;

  // Scroll behavior for nav background
  window.addEventListener('scroll', () => {
    if (window.scrollY > 100) {
      nav?.classList.add('glass-nav');
    } else {
      nav?.classList.remove('glass-nav');
    }
  });

  // Mobile menu toggle
  menuToggle?.addEventListener('click', () => {
    isMenuOpen = !isMenuOpen;

    if (isMenuOpen) {
      mobileMenu?.classList.remove('opacity-0', 'pointer-events-none');
      mobileMenu?.classList.add('opacity-100', 'pointer-events-auto');
      menuIcon?.setAttribute('d', 'M6 18L18 6M6 6l12 12');
      menuToggle.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';

      // Animate nav items
      mobileNavItems.forEach((item) => {
        item.classList.remove('opacity-0', 'translate-y-4');
        item.classList.add('opacity-100', 'translate-y-0');
      });
    } else {
      mobileMenu?.classList.add('opacity-0', 'pointer-events-none');
      mobileMenu?.classList.remove('opacity-100', 'pointer-events-auto');
      menuIcon?.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
      menuToggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';

      // Reset nav items
      mobileNavItems.forEach((item) => {
        item.classList.add('opacity-0', 'translate-y-4');
        item.classList.remove('opacity-100', 'translate-y-0');
      });
    }
  });
</script>

<style>
  .mobile-nav-item {
    transition: opacity 0.4s ease-out, transform 0.4s ease-out;
  }
</style>
